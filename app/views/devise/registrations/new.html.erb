<div class="container-fluid d-flex align-items-center justify-content-center min-vh-100">
  <div class="row w-100">
    <div class="col-lg-4 col-md-6 col-sm-8 mx-auto">
      <div class="pet-card p-5 position-relative">
        <!-- Decorative elements -->
        <i class="fas fa-heart pet-decoration top-left"></i>
        <i class="fas fa-paw pet-decoration bottom-right"></i>
        
        <div class="text-center mb-4">
          <i class="fas fa-user-plus pet-icon"></i>
          <h2 class="fw-bold text-primary mb-2">Criar Conta</h2>
          <p class="text-muted">Junte-se ao AgendaPet</p>
        </div>

        <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { class: "needs-validation", novalidate: true }) do |f| %>
          <%= render "devise/shared/error_messages", resource: resource %>

          <div class="mb-4">
            <label for="user_email" class="form-label fw-semibold">
              <i class="fas fa-envelope me-2 text-primary"></i>Email
            </label>
            <%= f.email_field :email, autofocus: true, autocomplete: "email", 
                class: "form-control pet-input", 
                placeholder: "Digite seu email",
                required: true %>
            <div class="invalid-feedback">
              Por favor, insira um email válido.
            </div>
          </div>

          <div class="mb-4">
            <label for="user_password" class="form-label fw-semibold">
              <i class="fas fa-lock me-2 text-primary"></i>Senha
              <% if @minimum_password_length %>
                <small class="text-muted">(mínimo <%= @minimum_password_length %> caracteres)</small>
              <% end %>
            </label>
            <%= f.password_field :password, autocomplete: "new-password", 
                class: "form-control pet-input", 
                placeholder: "Digite sua senha",
                required: true %>
            <div class="invalid-feedback">
              Por favor, insira uma senha válida.
            </div>
          </div>

          <div class="mb-4">
            <label for="user_password_confirmation" class="form-label fw-semibold">
              <i class="fas fa-lock me-2 text-primary"></i>Confirmar Senha
            </label>
            <%= f.password_field :password_confirmation, autocomplete: "new-password", 
                class: "form-control pet-input", 
                placeholder: "Confirme sua senha",
                required: true %>
            <div class="invalid-feedback">
              Por favor, confirme sua senha.
            </div>
          </div>

          <div class="d-grid mb-4">
            <%= f.submit "Criar Conta", class: "btn btn-primary pet-btn text-white fw-bold" %>
          </div>
        <% end %>

        <div class="text-center">
          <p class="text-muted mb-3">Já tem uma conta?</p>
          <%= link_to "Fazer Login", new_user_session_path, 
              class: "btn btn-outline-primary pet-btn fw-bold" %>
        </div>

        <!-- Pet shop benefits -->
        <div class="row mt-5 text-center">
          <div class="col-4">
            <i class="fas fa-calendar-check text-primary mb-2"></i>
            <small class="d-block text-muted">Agende</small>
          </div>
          <div class="col-4">
            <i class="fas fa-star text-primary mb-2"></i>
            <small class="d-block text-muted">Avalie</small>
          </div>
          <div class="col-4">
            <i class="fas fa-bell text-primary mb-2"></i>
            <small class="d-block text-muted">Notifique</small>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
// Bootstrap form validation
(function() {
  'use strict';
  window.addEventListener('load', function() {
    var forms = document.getElementsByClassName('needs-validation');
    var validation = Array.prototype.filter.call(forms, function(form) {
      form.addEventListener('submit', function(event) {
        if (form.checkValidity() === false) {
          event.preventDefault();
          event.stopPropagation();
        }
        form.classList.add('was-validated');
      }, false);
    });
  }, false);
})();
</script>
