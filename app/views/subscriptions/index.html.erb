<div class="container-fluid">
  <!-- Header -->
  <div class="row py-4">
    <div class="col-12">
      <div class="d-flex justify-content-between align-items-center">
        <div>
          <h1 class="fw-bold text-white mb-1">
            <i class="fas fa-credit-card me-2"></i>Planos e Assinaturas
          </h1>
          <p class="text-white-50 mb-0">Escolha o plano ideal para seu pet shop</p>
        </div>
        <div>
          <%= link_to "Voltar ao Dashboard", dashboard_path, 
              class: "btn btn-outline-light pet-btn" %>
        </div>
      </div>
    </div>
  </div>

  <!-- Status da Assinatura Atual -->
  <div class="row mb-5">
    <div class="col-12">
      <div class="pet-card p-4">
        <h4 class="fw-bold text-primary mb-3">
          <i class="fas fa-info-circle me-2"></i>Status Atual
        </h4>
        
        <div class="row align-items-center">
          <div class="col-md-8">
            <h5 class="mb-1"><%= @subscription.plan_name %></h5>
            <p class="text-muted mb-0">
              <% if @subscription.trial? %>
                <i class="fas fa-clock text-warning me-1"></i>
                Trial gratuito - <%= @subscription.days_remaining %> dias restantes
              <% elsif @subscription.active? %>
                <i class="fas fa-check-circle text-success me-1"></i>
                Assinatura ativa até <%= @subscription.current_period_end&.strftime("%d/%m/%Y") %>
              <% else %>
                <i class="fas fa-exclamation-triangle text-danger me-1"></i>
                Status: <%= @subscription.status.humanize %>
              <% end %>
            </p>
          </div>
          <div class="col-md-4 text-end">
            <% if @subscription.trial? %>
              <span class="badge bg-warning fs-6">Trial</span>
            <% elsif @subscription.active? %>
              <span class="badge bg-success fs-6">Ativo</span>
            <% else %>
              <span class="badge bg-danger fs-6">Inativo</span>
            <% end %>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Planos Disponíveis -->
  <div class="row g-4">
    <% @plans.each do |plan_key, plan_data| %>
      <div class="col-lg-4 col-md-6">
        <div class="pet-card p-4 h-100 position-relative">
          <% if plan_key == 'premium' %>
            <div class="position-absolute top-0 end-0 m-3">
              <span class="badge bg-primary">Mais Popular</span>
            </div>
          <% end %>
          
          <div class="text-center mb-4">
            <i class="fas fa-<%= plan_key == 'basic' ? 'paw' : plan_key == 'premium' ? 'star' : 'crown' %> text-primary mb-3" style="font-size: 3rem;"></i>
            <h4 class="fw-bold text-primary"><%= plan_data[:name] %></h4>
            <div class="mb-3">
              <span class="display-6 fw-bold text-primary">R$ <%= plan_data[:price] %></span>
              <span class="text-muted">/mês</span>
            </div>
          </div>

          <!-- Features do Plano -->
          <ul class="list-unstyled mb-4">
            <% case plan_key %>
            <% when 'basic' %>
              <li class="mb-2"><i class="fas fa-check text-success me-2"></i>Até 50 agendamentos/mês</li>
              <li class="mb-2"><i class="fas fa-check text-success me-2"></i>1 pet por conta</li>
              <li class="mb-2"><i class="fas fa-check text-success me-2"></i>Suporte por email</li>
              <li class="mb-2"><i class="fas fa-check text-success me-2"></i>Relatórios básicos</li>
            <% when 'premium' %>
              <li class="mb-2"><i class="fas fa-check text-success me-2"></i>Agendamentos ilimitados</li>
              <li class="mb-2"><i class="fas fa-check text-success me-2"></i>Até 5 pets por conta</li>
              <li class="mb-2"><i class="fas fa-check text-success me-2"></i>Suporte prioritário</li>
              <li class="mb-2"><i class="fas fa-check text-success me-2"></i>Relatórios avançados</li>
              <li class="mb-2"><i class="fas fa-check text-success me-2"></i>Integração WhatsApp</li>
            <% when 'enterprise' %>
              <li class="mb-2"><i class="fas fa-check text-success me-2"></i>Tudo do Premium</li>
              <li class="mb-2"><i class="fas fa-check text-success me-2"></i>Pets ilimitados</li>
              <li class="mb-2"><i class="fas fa-check text-success me-2"></i>Suporte 24/7</li>
              <li class="mb-2"><i class="fas fa-check text-success me-2"></i>API personalizada</li>
              <li class="mb-2"><i class="fas fa-check text-success me-2"></i>Gerente dedicado</li>
            <% end %>
          </ul>

          <!-- Botão de Ação -->
          <div class="d-grid">
            <% if @subscription.plan_type == plan_key && @subscription.active? %>
              <%= link_to "Plano Atual", "#", 
                  class: "btn btn-outline-primary pet-btn disabled" %>
            <% else %>
              <%= link_to "Escolher Plano", subscriptions_path(plan_type: plan_key), 
                  method: :post,
                  class: "btn btn-primary pet-btn fw-bold",
                  data: { 
                    confirm: "Tem certeza que deseja escolher o #{plan_data[:name]}?",
                    turbo_method: :post
                  } %>
            <% end %>
          </div>
        </div>
      </div>
    <% end %>
  </div>

  <!-- Informações Adicionais -->
  <div class="row mt-5">
    <div class="col-12">
      <div class="pet-card p-4">
        <h5 class="fw-bold text-primary mb-3">
          <i class="fas fa-shield-alt me-2"></i>Garantia e Segurança
        </h5>
        <div class="row">
          <div class="col-md-4 text-center">
            <i class="fas fa-lock text-primary mb-2" style="font-size: 2rem;"></i>
            <h6 class="fw-bold">Pagamento Seguro</h6>
            <small class="text-muted">Processado pelo Stripe</small>
          </div>
          <div class="col-md-4 text-center">
            <i class="fas fa-undo text-primary mb-2" style="font-size: 2rem;"></i>
            <h6 class="fw-bold">Cancelamento Fácil</h6>
            <small class="text-muted">Cancele a qualquer momento</small>
          </div>
          <div class="col-md-4 text-center">
            <i class="fas fa-headset text-primary mb-2" style="font-size: 2rem;"></i>
            <h6 class="fw-bold">Suporte 24/7</h6>
            <small class="text-muted">Estamos sempre aqui para ajudar</small>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
