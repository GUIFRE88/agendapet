<div class="container-fluid">
  <!-- Hero Section -->
  <div class="row min-vh-100 align-items-center">
    <div class="col-lg-6 text-center text-lg-start">
      <div class="px-4">
        <h1 class="display-4 fw-bold text-white mb-4">
          <i class="fas fa-paw me-3"></i>AgendaPet
        </h1>
        <p class="lead text-white mb-4">
          O sistema completo de agendamento para seu pet shop. 
          Gerencie consultas, banhos, tosas e muito mais com facilidade e amor.
        </p>
        <div class="d-flex flex-column flex-sm-row gap-3">
          <%= link_to "Fazer Login", new_user_session_path, 
              class: "btn btn-light btn-lg pet-btn fw-bold" %>
          <%= link_to "Criar Conta", new_user_registration_path, 
              class: "btn btn-outline-light btn-lg pet-btn fw-bold" %>
        </div>
      </div>
    </div>
    
    <div class="col-lg-6 text-center">
      <div class="pet-card p-5 mx-auto" style="max-width: 500px;">
        <i class="fas fa-heart pet-icon"></i>
        <h3 class="fw-bold text-primary mb-3">Bem-vindo ao AgendaPet</h3>
        <p class="text-muted mb-4">
          Seu pet merece o melhor cuidado. Agende consultas, banhos e serviços 
          com profissionais especializados.
        </p>
        
        <!-- Features -->
        <div class="row g-3">
          <div class="col-6">
            <div class="text-center p-3">
              <i class="fas fa-calendar-alt text-primary mb-2" style="font-size: 2rem;"></i>
              <h6 class="fw-bold">Agendamentos</h6>
              <small class="text-muted">Fácil e rápido</small>
            </div>
          </div>
          <div class="col-6">
            <div class="text-center p-3">
              <i class="fas fa-paw text-primary mb-2" style="font-size: 2rem;"></i>
              <h6 class="fw-bold">Pet Care</h6>
              <small class="text-muted">Cuidado especializado</small>
            </div>
          </div>
          <div class="col-6">
            <div class="text-center p-3">
              <i class="fas fa-star text-primary mb-2" style="font-size: 2rem;"></i>
              <h6 class="fw-bold">Avaliações</h6>
              <small class="text-muted">Qualidade garantida</small>
            </div>
          </div>
          <div class="col-6">
            <div class="text-center p-3">
              <i class="fas fa-bell text-primary mb-2" style="font-size: 2rem;"></i>
              <h6 class="fw-bold">Lembretes</h6>
              <small class="text-muted">Nunca esqueça</small>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Features Section -->
  <div class="row py-5">
    <div class="col-12 text-center mb-5">
      <h2 class="fw-bold text-white mb-3">Por que escolher o AgendaPet?</h2>
      <p class="text-white-50">Tecnologia e amor pelos pets em um só lugar</p>
    </div>
    
    <div class="col-lg-4 col-md-6 mb-4">
      <div class="pet-card p-4 h-100 text-center">
        <i class="fas fa-clock text-primary mb-3" style="font-size: 3rem;"></i>
        <h5 class="fw-bold mb-3">Agendamento 24/7</h5>
        <p class="text-muted">Agende seus serviços a qualquer hora, de qualquer lugar.</p>
      </div>
    </div>
    
    <div class="col-lg-4 col-md-6 mb-4">
      <div class="pet-card p-4 h-100 text-center">
        <i class="fas fa-user-md text-primary mb-3" style="font-size: 3rem;"></i>
        <h5 class="fw-bold mb-3">Profissionais Qualificados</h5>
        <p class="text-muted">Veterinários e pet groomers experientes e carinhosos.</p>
      </div>
    </div>
    
    <div class="col-lg-4 col-md-6 mb-4">
      <div class="pet-card p-4 h-100 text-center">
        <i class="fas fa-shield-alt text-primary mb-3" style="font-size: 3rem;"></i>
        <h5 class="fw-bold mb-3">Segurança Total</h5>
        <p class="text-muted">Seus dados e do seu pet protegidos com máxima segurança.</p>
      </div>
    </div>
  </div>

  <!-- CTA Section -->
  <div class="row py-5">
    <div class="col-12 text-center">
      <div class="pet-card p-5 mx-auto" style="max-width: 600px;">
        <i class="fas fa-heart text-primary mb-3" style="font-size: 4rem;"></i>
        <h3 class="fw-bold text-primary mb-3">Pronto para começar?</h3>
        <p class="text-muted mb-4">
          Junte-se a milhares de tutores que já confiam no AgendaPet 
          para cuidar de seus amados pets.
        </p>
        <%= link_to "Criar Conta Gratuita", new_user_registration_path, 
            class: "btn btn-primary btn-lg pet-btn fw-bold" %>
      </div>
    </div>
  </div>
</div>
